{
  "name": "rawtree-firecracker-observability",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation for provider-side RawTree observability in Firecracker sandboxes.",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dry-run": "tsx src/orchestrator.ts --dry-run --kernel /var/lib/firecracker/vmlinux --rootfs /var/lib/firecracker/rootfs.ext4 --metadata provider=example --metadata environment=poc",
    "start": "tsx src/orchestrator.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
